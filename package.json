{
  "name": "gpt-image-playground",
  "private": true,
  "version": "0.3.53",
  "type": "module",
  "scripts": {
    "sync-version": "node scripts/sync-version.mjs",
    "release:tag": "npm run sync-version && node scripts/release-tag.mjs",
    "dev": "vite",
    "dev:server": "npm run sync-version && npm --prefix server run dev",
    "build:server": "npm run sync-version && npm --prefix server run build",
    "build": "npm run sync-version && tsc -b && vite build",
    "build:web": "npm run sync-version && tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fabric": "^7.3.1",
    "fflate": "^0.8.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vitest": "^4.1.5"
  }
}
